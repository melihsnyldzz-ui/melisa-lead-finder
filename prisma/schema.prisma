generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  HOT
  REVIEW
  QUALIFIED
  CONTACT_READY
  CONTACTED
  REPLIED
  CATALOG_SENT
  OFFER_SENT
  WON
  LOST
  NURTURE
  LOW_QUALITY
  REJECTED
  CONVERTED
}

enum LeadFeedback {
  NONE
  LIKED
  DISLIKED
}

enum SourceType {
  DEMO
  GOOGLE_PLACES
  APIFY
  INSTAGRAM_APIFY
  WEBSITE
  WEBSITE_SCAN
  CSV_IMPORT
  INSTAGRAM
  MANUAL
}

enum SearchTaskStatus {
  DRAFT
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  VIP
}

enum RiskLabel {
  REAL_STORE
  WHOLESALER
  ONLINE_SELLER
  INFLUENCER
  PERSONAL_ACCOUNT
  IRRELEVANT_CATEGORY
  INACTIVE
  UNKNOWN
}

enum LeadActivityType {
  NOTE
  STATUS_CHANGE
  FEEDBACK
  AI_ANALYSIS
  SEARCH_DISCOVERY
  CONTACT_ATTEMPT
  CATALOG_SENT
  OFFER_SENT
  REPLY_RECEIVED
  WON
  LOST
  REJECTED
  NURTURE
}

model Lead {
  id            String     @id @default(cuid())
  googlePlaceId String?
  companyName   String
  displayName   String?
  country       String
  city          String?
  category      String?
  address       String?
  phone         String?
  internationalPhoneNumber String?
  whatsapp      String?
  email         String?
  website       String?
  instagram     String?
  googleMapsUrl String?
  sourceType    SourceType @default(DEMO)
  sourceQuery   String?
  sourceKeyword String?
  sourceCity    String?
  sourceCountry String?
  leadScore     Int        @default(0)
  combinedScore Int        @default(0)
  fitScore       Int        @default(0)
  contactScore   Int        @default(0)
  activityScore  Int        @default(0)
  potentialScore Int        @default(0)
  riskScore      Int        @default(0)
  scoreReason   String?
  categoryGuess String?
  businessStatus String?
  types         String[]   @default([])
  openingHours  Json?
  rating        Float?
  userRatingsTotal Int?
  status        LeadStatus @default(NEW)
  priority      LeadPriority @default(MEDIUM)
  riskLabel     RiskLabel  @default(UNKNOWN)
  nextBestAction String?
  nextFollowUpDate DateTime?
  userFeedback  LeadFeedback @default(NONE)
  userFeedbackAt DateTime?
  assignedTo    String?
  notes         String?
  aiAnalysis    Json?
  aiAnalyzedAt  DateTime?
  rawPayload    Json?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  sources           LeadSource[]
  instagramProfiles InstagramProfile[]
  activities        LeadActivity[]

  @@index([country])
  @@index([city])
  @@index([status])
  @@index([priority])
  @@index([leadScore])
  @@index([combinedScore])
  @@index([googlePlaceId])
}

model LeadSource {
  id              String     @id @default(cuid())
  leadId          String
  lead            Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sourceType      SourceType
  sourceName      String?
  sourceUrl       String?
  sourceQuery     String?
  rawPayload      Json?
  confidenceScore Int        @default(0)
  createdAt       DateTime   @default(now())

  @@index([leadId])
  @@index([sourceType])
  @@index([sourceQuery])
}

model InstagramProfile {
  id                    String    @id @default(cuid())
  leadId                String
  lead                  Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  username              String?
  profileName           String?
  profileUrl            String?
  bio                   String?
  followerCount         Int?
  followingCount        Int?
  postCount             Int?
  lastPostDate          DateTime?
  language              String?
  countrySignal         String?
  citySignal            String?
  phone                 String?
  whatsapp              String?
  email                 String?
  website               String?
  riskLabel             RiskLabel @default(UNKNOWN)
  aiScore               Int?
  aiScoreReason         String?
  suggestedFirstMessage String?
  rawPayload            Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([leadId])
  @@index([username])
  @@index([profileUrl])
}

model LeadActivity {
  id           String           @id @default(cuid())
  leadId       String
  lead         Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  activityType LeadActivityType
  channel      String?
  content      String?
  result       String?
  createdBy    String?
  createdAt    DateTime         @default(now())

  @@index([leadId])
  @@index([activityType])
  @@index([createdAt])
}

model SearchTask {
  id          String           @id @default(cuid())
  name        String
  country     String
  city        String?
  language    String?
  keywordGroup String?
  sourceKeyword String?
  query       String
  sourceType  SourceType       @default(DEMO)
  maxResults  Int              @default(50)
  status      SearchTaskStatus @default(DRAFT)
  foundCount  Int              @default(0)
  insertedCount Int             @default(0)
  duplicateCount Int            @default(0)
  errorCount Int                @default(0)
  averageScore Float?
  error       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model SearchRunHistory {
  id           String           @id @default(cuid())
  taskId       String?
  country      String
  city         String?
  keywordGroup String?
  sourceKeyword String?
  query        String
  sourceType   SourceType
  status       SearchTaskStatus
  foundCount   Int              @default(0)
  createdCount Int              @default(0)
  duplicateCount Int            @default(0)
  errorCount Int                @default(0)
  averageScore Float?
  error        String?
  ranAt        DateTime         @default(now())

  @@index([country, city, query, sourceType])
  @@index([ranAt])
}

model CompanyProfile {
  id                    String   @id @default("default")
  companyName           String
  description           String
  productCategories     String[] @default([])
  targetCustomerTypes   String[] @default([])
  excludedCustomerTypes String[] @default([])
  targetCountries       String[] @default([])
  valueProposition      String
  salesTone             String
  minimumOrderNote      String?
  outreachLanguage      String   @default("tr")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
